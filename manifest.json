{
  "manifest_version": 3,
  "name": "清新新标签页",
  "version": "0.0.1",
  "description": "清新风格的新标签页，包含时钟、问候语和多引擎搜索",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://picsum.photos/*", "https://www.google.com/*"]
}
